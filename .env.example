# LLM API key (required — pick one)
GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
TEX_API_KEY = tex-...
TEX_BASE_URL = https://texapi.dev/v1

# Optional: override default model
# LLM_MODEL=gemini-2.5-flash
TEX_MODEL = glm-4.7-free

# Optional: real HITL interrupts (default: mock approval)
# LANGGRAPH_INTERRUPT=true
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT="Vin"

# Optional: persistence backend
CHECKPOINTER=memory
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph_lab

LOG_LEVEL=INFO
